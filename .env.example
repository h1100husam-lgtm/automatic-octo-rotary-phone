# ═══════════════════════════════════════════
# مثال ملف .env - انسخه إلى .env واملأ المفاتيح
# cp .env.example .env
# ═══════════════════════════════════════════

# === المفاتيح ===
TELEGRAM_TOKEN=                # من @BotFather
GROQ_API_KEY=                  # من console.groq.com
GEMINI_API_KEY=                # اختياري - من aistudio.google.com
OPENAI_API_KEY=                # اختياري - للـ TTS لاحقًا

# === الموفّر ===
# groq | gemini | openai
AI_PROVIDER=groq

# النماذج (اختياري)
AI_MODEL=llama-3.3-70b-versatile
GEMINI_MODEL=gemini-2.5-flash
OPENAI_MODEL=gpt-4o-mini

# === الشخصية ===
AGENT_NAME=سارة
AGENT_GENDER=female
AGENT_TONE=friendly
AGENT_LOCALE=ar-SA

# === صلاحيات ===
BROWSER_AUTO_LOGIN=false
MAX_TOOL_ITERATIONS=5
